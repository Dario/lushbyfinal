<section class="promo-grid">
  <div class="page-width promo-grid__inner">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link }}" class="promo-card" {{ block.shopify_attributes }}>
        <span class="promo-card__media">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1400 | image_tag: alt: block.settings.heading, class: 'promo-card__image' }}
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'promo-card__image' }}
          {%- endif -%}
        </span>
        <span class="promo-card__overlay">
          {%- if block.settings.subheading != blank -%}
            <span class="promo-card__sub">{{ block.settings.subheading }}</span>
          {%- endif -%}
          <span class="promo-card__heading">{{ block.settings.heading }}</span>
          {%- if block.settings.text != blank -%}
            <span class="promo-card__text">{{ block.settings.text }}</span>
          {%- endif -%}
          {%- if block.settings.link_label != blank -%}
            <span class="promo-card__link">{{ block.settings.link_label }}</span>
          {%- endif -%}
        </span>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Promo grid",
  "blocks": [
    {
      "type": "promo",
      "name": "Promo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "subheading", "label": "Eyebrow" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Skincare ritual" },
        { "type": "text", "id": "text", "label": "Text", "default": "Build your barrier with clean, conscious formulas." },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Discover" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 3,
  "default": {
    "blocks": [
      { "type": "promo", "settings": { "heading": "Skincare ritual" } },
      { "type": "promo", "settings": { "heading": "Signature scents" } }
    ]
  },
  "presets": [{ "name": "Promo grid" }]
}
{% endschema %}
