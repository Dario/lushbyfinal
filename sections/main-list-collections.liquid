<section class="list-collections">
  <div class="page-width">
    <h1 class="list-collections__title">All collections</h1>
    <div class="list-collections__grid">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" class="list-collections__card">
          {%- if collection.image -%}
            {{ collection.image | image_url: width: 800 | image_tag: alt: collection.title, class: 'list-collections__image' }}
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'list-collections__image' }}
          {%- endif -%}
          <h2 class="list-collections__name">{{ collection.title }}</h2>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "List collections",
  "settings": []
}
{% endschema %}
