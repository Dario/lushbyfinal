<section class="password-page">
  <div class="page-width password-page__inner">
    <h1 class="password-page__heading">{{ section.settings.heading }}</h1>
    <p class="password-page__subheading">{{ section.settings.subheading }}</p>

    {%- if shop.password_message != blank -%}
      <div class="password-page__message rte">{{ shop.password_message }}</div>
    {%- endif -%}

    {%- form 'storefront_password', class: 'password-form' -%}
      <label for="Password">Enter store password</label>
      <input type="password" id="Password" name="password" placeholder="Password" required>
      <button type="submit" class="btn btn--primary">Enter</button>
      {{ form.errors | default_errors }}
    {%- endform -%}

    <p class="password-page__owner">
      Are you the store owner? <a href="/admin">Log in</a>
    </p>
  </div>
</section>

{% schema %}
{
  "name": "Password",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Opening soon" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "A new beauty destination, launching soon. Sign up to be the first to know." }
  ]
}
{% endschema %}
