<footer class="site-footer">
  <div class="page-width site-footer__inner">
    <div class="site-footer__grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'text' -%}
            <div class="site-footer__col" {{ block.shopify_attributes }}>
              <h4 class="site-footer__heading">{{ block.settings.heading }}</h4>
              <div class="site-footer__text">{{ block.settings.text }}</div>
            </div>
          {%- when 'menu' -%}
            <div class="site-footer__col" {{ block.shopify_attributes }}>
              <h4 class="site-footer__heading">{{ block.settings.heading }}</h4>
              <ul class="site-footer__menu">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            </div>
          {%- when 'newsletter' -%}
            <div class="site-footer__col site-footer__col--newsletter" {{ block.shopify_attributes }}>
              <h4 class="site-footer__heading">{{ block.settings.heading }}</h4>
              <p>{{ block.settings.subheading }}</p>
              {%- form 'customer', class: 'site-footer__newsletter-form' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <input type="email" name="contact[email]" placeholder="Email address" required>
                <button type="submit">Sign up</button>
              {%- endform -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <div class="site-footer__bottom">
      <p class="site-footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      {%- if section.settings.show_payment_icons -%}
        <ul class="site-footer__payment">
          {%- for type in shop.enabled_payment_types -%}
            <li>{{ type | payment_type_svg_tag: class: 'site-footer__payment-icon' }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "checkbox", "id": "show_payment_icons", "label": "Show payment icons", "default": true }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "About" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>A modern beauty destination.</p>" }
      ]
    },
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Stay in the glow" },
        { "type": "text", "id": "subheading", "label": "Subheading", "default": "New arrivals, exclusive offers, and beauty tips." }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "text" },
      { "type": "menu" },
      { "type": "newsletter" }
    ]
  }
}
{% endschema %}
