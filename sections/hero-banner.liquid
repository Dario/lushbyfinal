{%- assign slide_count = section.blocks.size -%}
<section
  class="hero-banner hero-banner--{{ section.settings.height }} hero-slider"
  data-hero-slider
  data-autoplay="{{ section.settings.autoplay_speed | times: 1000 }}"
  {% if section.settings.enable_glitter %}data-glitter{% endif %}
>
  {%- for block in section.blocks -%}
    {%- assign ph = forloop.index0 | modulo: 3 | plus: 1 -%}
    <div class="hero-slider__slide{% if forloop.first %} is-active{% endif %}" data-hero-slide {{ block.shopify_attributes }}>
      {%- if block.settings.bg_image != blank -%}
        <div class="hero-slider__bg" style="background-image: url('{{ block.settings.bg_image | image_url: width: 2400 }}');"></div>
      {%- else -%}
        <div class="hero-slider__bg hero-slider__bg--placeholder-{{ ph }}"></div>
      {%- endif -%}
    </div>
  {%- endfor -%}

  <div class="hero-banner__overlay hero-banner__overlay--{{ section.settings.text_align }}" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>

  <div class="page-width hero-banner__inner hero-banner__inner--{{ section.settings.text_align }}">
    {%- for block in section.blocks -%}
      <div class="hero-slider__copy{% if forloop.first %} is-active{% endif %}" data-hero-copy>
        {%- if block.settings.subheading != blank -%}
          <p class="hero-banner__subheading">{{ block.settings.subheading }}</p>
        {%- endif -%}
        {%- if block.settings.heading != blank -%}
          {%- if forloop.first -%}
            <h1 class="hero-banner__heading">{{ block.settings.heading }}</h1>
          {%- else -%}
            <p class="hero-banner__heading" role="heading" aria-level="2">{{ block.settings.heading }}</p>
          {%- endif -%}
        {%- endif -%}
        {%- if block.settings.text != blank -%}
          <div class="hero-banner__text">{{ block.settings.text }}</div>
        {%- endif -%}
        {%- if block.settings.button_label != blank -%}
          <a href="{{ block.settings.button_url }}" class="btn btn--primary" data-sparkle-cta>{{ block.settings.button_label }}</a>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  {%- if slide_count > 1 -%}
    <div class="hero-slider__dots" data-hero-dots>
      {%- for block in section.blocks -%}
        <button type="button" class="{% if forloop.first %}is-active{% endif %}" data-hero-dot aria-label="Slide {{ forloop.index }} of {{ slide_count }}"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero slider",
  "settings": [
    {
      "type": "select", "id": "height", "label": "Height", "default": "large",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full", "label": "Full screen" }
      ]
    },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 80, "step": 5, "unit": "%", "default": 20 },
    {
      "type": "select", "id": "text_align", "label": "Text alignment", "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    { "type": "range", "id": "autoplay_speed", "label": "Slide duration", "min": 3, "max": 8, "step": 1, "unit": "s", "default": 5 },
    { "type": "checkbox", "id": "enable_glitter", "label": "Glitter burst on button hover", "default": true }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "bg_image", "label": "Background image" },
        { "type": "text", "id": "subheading", "label": "Subheading", "default": "NEW THIS WEEK" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Beauty without limits" },
        { "type": "richtext", "id": "text", "label": "Text" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
        { "type": "url", "id": "button_url", "label": "Button URL" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Hero slider",
      "blocks": [
        { "type": "slide", "settings": { "subheading": "NEW THIS WEEK", "heading": "Beauty without limits", "button_label": "Shop now" } },
        { "type": "slide", "settings": { "subheading": "NEW IN FRAGRANCE", "heading": "Find your signature scent", "button_label": "Explore fragrance" } }
      ]
    }
  ]
}
{% endschema %}
