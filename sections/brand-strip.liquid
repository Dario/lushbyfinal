<section class="brand-strip">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <p class="brand-strip__heading">{{ section.settings.heading }}</p>
    {%- endif -%}
    <div class="brand-strip__row">
      {%- for block in section.blocks -%}
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" class="brand-strip__brand" {{ block.shopify_attributes }}>{{ block.settings.name }}</a>
        {%- else -%}
          <span class="brand-strip__brand" {{ block.shopify_attributes }}>{{ block.settings.name }}</span>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand strip",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop our brands"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Brand name",
          "default": "Aura Skin"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Brand strip",
      "blocks": [
        {
          "type": "brand",
          "settings": {
            "name": "Aura Skin"
          }
        },
        {
          "type": "brand",
          "settings": {
            "name": "Velvet & Co"
          }
        },
        {
          "type": "brand",
          "settings": {
            "name": "Botanica"
          }
        },
        {
          "type": "brand",
          "settings": {
            "name": "Lumi"
          }
        },
        {
          "type": "brand",
          "settings": {
            "name": "Maison Rose"
          }
        },
        {
          "type": "brand",
          "settings": {
            "name": "Pure Lab"
          }
        }
      ]
    }
  ]
}
{% endschema %}
