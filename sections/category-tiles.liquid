<section class="category-tiles">
  <div class="page-width">
    <header class="section-heading">
      {%- if section.settings.heading != blank -%}
        <h2 class="section-heading__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </header>
    <div class="category-tiles__grid" style="--tile-count: {{ section.blocks.size }};">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="category-tile" {{ block.shopify_attributes }}>
          <span class="category-tile__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: alt: block.settings.title, class: 'category-tile__image' }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'category-tile__image' }}
            {%- endif -%}
          </span>
          <h3 class="category-tile__title">{{ block.settings.title }}</h3>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category tiles",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by category"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Makeup"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Category tiles",
      "blocks": [
        {
          "type": "tile",
          "settings": {
            "title": "Makeup"
          }
        },
        {
          "type": "tile",
          "settings": {
            "title": "Skincare"
          }
        },
        {
          "type": "tile",
          "settings": {
            "title": "Fragrance"
          }
        },
        {
          "type": "tile",
          "settings": {
            "title": "Hair"
          }
        }
      ]
    }
  ]
}
{% endschema %}
