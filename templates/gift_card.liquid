<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ shop.name }} — Gift card</title>
    {{ 'theme.css' | asset_url | stylesheet_tag }}
  </head>
  <body class="template-gift-card">
    <div class="page-width" style="max-width: 540px; padding: 64px 24px; text-align: center;">
      <h1 style="margin-bottom: 8px;">Gift card</h1>
      <p style="margin-bottom: 32px; color: rgba(0,0,0,0.6);">From {{ shop.name }}</p>

      <div style="background: rgb(var(--color-fg)); color: rgb(var(--color-bg)); padding: 40px 24px; margin-bottom: 24px;">
        <p style="font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; margin: 0 0 8px; opacity: 0.7;">Value</p>
        <p style="font-size: 2.5rem; font-weight: 700; margin: 0 0 24px;">{{ gift_card.initial_value | money }}</p>
        {%- if gift_card.enabled and gift_card.balance > 0 -%}
          <p style="font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; margin: 0; opacity: 0.7;">Remaining balance</p>
          <p style="font-size: 1.25rem; font-weight: 600; margin: 4px 0 0;">{{ gift_card.balance | money }}</p>
        {%- elsif gift_card.expired -%}
          <p style="margin: 0; opacity: 0.7;">This gift card has expired.</p>
        {%- endif -%}
      </div>

      <div style="background: rgba(0,0,0,0.04); padding: 16px; font-family: monospace; font-size: 1.125rem; letter-spacing: 0.1em; margin-bottom: 24px;">
        {{ gift_card.code | format_code }}
      </div>

      <p style="font-size: 0.875rem; color: rgba(0,0,0,0.6); margin-bottom: 24px;">
        Use this code at checkout to redeem your gift card.
      </p>

      <a href="{{ shop.url }}" class="btn btn--primary">Shop now</a>
    </div>
  </body>
</html>
