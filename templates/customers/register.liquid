<section class="auth-page">
  <div class="page-width auth-page__inner">
    <h1>Create account</h1>
    {%- form 'create_customer', class: 'auth-form' -%}
      {{ form.errors | default_errors }}
      <label for="FirstName">First name</label>
      <input type="text" id="FirstName" name="customer[first_name]" autocomplete="given-name">
      <label for="LastName">Last name</label>
      <input type="text" id="LastName" name="customer[last_name]" autocomplete="family-name">
      <label for="Email">Email</label>
      <input type="email" id="Email" name="customer[email]" autocomplete="email" required>
      <label for="Password">Password</label>
      <input type="password" id="Password" name="customer[password]" autocomplete="new-password" required>
      <button type="submit" class="btn btn--primary btn--block">Create account</button>
    {%- endform -%}
  </div>
</section>
