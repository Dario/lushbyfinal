<section class="auth-page">
  <div class="page-width auth-page__inner">
    <h1>Sign in</h1>
    {%- form 'customer_login', class: 'auth-form' -%}
      {{ form.errors | default_errors }}
      <label for="CustomerEmail">Email</label>
      <input type="email" id="CustomerEmail" name="customer[email]" autocomplete="email" required>
      <label for="CustomerPassword">Password</label>
      <input type="password" id="CustomerPassword" name="customer[password]" autocomplete="current-password" required>
      <button type="submit" class="btn btn--primary btn--block">Sign in</button>
      <a href="{{ routes.account_recover_url }}" class="auth-form__link">Forgot password?</a>
    {%- endform -%}
    <p>New here? <a href="{{ routes.account_register_url }}">Create an account</a></p>
  </div>
</section>
